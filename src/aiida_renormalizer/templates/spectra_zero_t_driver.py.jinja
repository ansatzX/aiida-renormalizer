"""Driver script for SpectraZeroTCalcJob.

Zero-temperature absorption/emission spectrum calculation.
"""
import json
import numpy as np
from renormalizer.model import Model
from renormalizer.mps import Mps, Mpo
from renormalizer.spectra import SpectraOneWayPropZeroT, SpectraTwoWayPropZeroT
from renormalizer.utils import Quantity, OptimizeConfig

# ============================================================================
# INPUT LOADING UTILITIES (from base template)
# ============================================================================

def load_model(input_file='input_model.json'):
    """Load a Reno Model from AiiDA ModelData export."""
    with open(input_file, 'r') as f:
        data = json.load(f)

    from aiida_renormalizer.data.basis_registry import deserialize_basis
    basis = [deserialize_basis(b) for b in data['basis']]

    from aiida_renormalizer.data.op import deserialize_opsum
    ham_terms = deserialize_opsum(data['ham_opsum'])

    dipole = None
    if 'dipole' in data:
        dipole = deserialize_opsum(data['dipole'])

    return Model(basis, ham_terms, dipole=dipole)

def load_mps(input_file='initial_mps.npz', model=None):
    """Load an MPS/MpDm from .npz file."""
    if model is None:
        raise ValueError("Model is required to load MPS")
    return Mps.load(model, input_file)

def load_mpo(input_file='initial_mpo.npz', model=None):
    """Load an MPO from .npz file."""
    if model is None:
        raise ValueError("Model is required to load MPO")
    return Mpo.load(model, input_file)

def load_config(input_file='input_config.json'):
    """Load a Reno config object from AiiDA ConfigData export."""
    try:
        with open(input_file, 'r') as f:
            data = json.load(f)
        # Reconstruct EvolveConfig from data
        from renormalizer.utils.configs import EvolveConfig
        config_class = data.get('config_class', 'EvolveConfig')
        fields = data.get('fields', {})
        return EvolveConfig(**fields)
    except FileNotFoundError:
        # Return default config
        from renormalizer.utils.configs import EvolveConfig
        return EvolveConfig()

# ============================================================================
# OUTPUT SERIALIZATION UTILITIES (from base template)
# ============================================================================

def save_output_parameters(params, output_file='output_parameters.json'):
    """Save calculation outputs to JSON."""
    with open(output_file, 'w') as f:
        json.dump(params, f, indent=2)

# ============================================================================
# MAIN CALCULATION
# ============================================================================

if __name__ == '__main__':
    # Load inputs
    model = load_model()

    # Load spectrum parameters
    with open('input_spectra_params.json', 'r') as f:
        params = json.load(f)

    spectratype = params['spectratype']
    propagation = params.get('propagation', 'two_way')
    offset = params.get('offset', 0.0)

    # Load config
    config = load_config()

    # Load MPO (if provided)
    {% if has_mpo %}
    mpo = load_mpo('initial_mpo.npz', model)
    {% else %}
    mpo = Mpo(model)
    {% endif %}

    # Load initial MPS (if provided)
    {% if has_initial_mps %}
    initial_mps = load_mps('initial_mps.npz', model)
    {% else %}
    initial_mps = None
    {% endif %}

    # Create spectrum calculator
    if propagation == 'one_way':
        spectra_calc = SpectraOneWayPropZeroT(
            model,
            spectratype,
            optimize_config=None,
            evolve_config=config,
            offset=Quantity(offset)
        )
    else:  # two_way
        spectra_calc = SpectraTwoWayPropZeroT(
            model,
            spectratype,
            optimize_config=None,
            evolve_config=config,
            offset=Quantity(offset)
        )

    # If initial MPS provided, would need to set it
    # For now, let the calculator optimize the ground state

    # Run calculation
    # Note: This is a simplified version. The actual API may need adjustment
    # based on how TdMpsJob works
    try:
        # Run time evolution
        # The exact API call depends on how TdMpsJob is used
        # For now, use a placeholder
        spectra_calc.evolve(None, None, None)

        # Get results
        time_series = spectra_calc.evolve_times
        autocorr = spectra_calc.autocorr

        # Prepare output
        output_params = {
            'calcjob_class': 'SpectraZeroTCalcJob',
            'calc_type': 'spectra',
            'spectratype': spectratype,
            'propagation': propagation,
            'temperature': 0.0,
            'time_series': [float(t) for t in time_series],
            'autocorr': [complex(c) for c in autocorr],
            'converged': True,
        }

        save_output_parameters(output_params)

    except Exception as e:
        import traceback
        output_params = {
            'calcjob_class': 'SpectraZeroTCalcJob',
            'error': str(e),
            'traceback': traceback.format_exc(),
            'converged': False,
        }
        save_output_parameters(output_params)
        raise
