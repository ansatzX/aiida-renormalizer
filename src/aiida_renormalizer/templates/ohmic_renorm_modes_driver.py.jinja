"""Driver script for OhmicRenormModesCalcJob."""
import json

import numpy as np
from renormalizer.sbm import SpectralDensityFunction
from renormalizer.utils import Quantity


def save_output_parameters(params, output_file="output_parameters.json"):
    with open(output_file, "w") as f:
        json.dump(params, f, indent=2)


def _ohmic_exp_modes(*, alpha, s_exp, omega_c, raw_delta, renorm_p, n_modes, method):
    sdf = SpectralDensityFunction(
        alpha=alpha,
        omega_c=Quantity(omega_c),
        s=s_exp,
    )
    delta_eff, omega_l = sdf.adiabatic_renormalization(Quantity(raw_delta), renorm_p)
    if method == "wang1":
        omega_k, c_j2 = sdf.Wang1(n_modes)
    elif method == "trapz":
        omega_k, c_j2 = sdf.trapz(n_modes, 0.0, omega_l)
    else:
        raise ValueError("ohmic_discretization must be 'wang1' or 'trapz'")
    return float(delta_eff), float(omega_l), np.asarray(omega_k, dtype=float), np.asarray(c_j2, dtype=float)


if __name__ == "__main__":
    with open("input_ohmic_renorm_modes.json", "r") as f:
        p = json.load(f)

    try:
        alpha = float(p["alpha"])
        s_exp = float(p["s_exponent"])
        omega_c = float(p["omega_c"])
        spectral_density_type = str(p.get("spectral_density_type", "ohmic_exp"))
        ohmic_discretization = str(p.get("ohmic_discretization", "wang1"))
        raw_delta = float(p["raw_delta"])
        renorm_p = float(p["renormalization_p"])
        n_modes = int(p["n_modes"])

        if omega_c <= 0:
            raise ValueError("omega_c must be > 0")
        if raw_delta <= 0:
            raise ValueError("raw_delta must be > 0")
        if renorm_p <= 0:
            raise ValueError("renormalization_p must be > 0")
        if n_modes <= 0:
            raise ValueError("n_modes must be > 0")
        if spectral_density_type != "ohmic_exp":
            raise ValueError("Only spectral_density_type='ohmic_exp' is supported")
        delta_eff_f, omega_l_f, omega_k_arr, c_j2_arr = _ohmic_exp_modes(
            alpha=alpha,
            s_exp=s_exp,
            omega_c=omega_c,
            raw_delta=raw_delta,
            renorm_p=renorm_p,
            n_modes=n_modes,
            method=ohmic_discretization,
        )

        output = {
            "calcjob_class": "OhmicRenormModesCalcJob",
            "calc_type": "ohmic_renorm_modes",
            "alpha": alpha,
            "s_exponent": s_exp,
            "omega_c": omega_c,
            "spectral_density_type": spectral_density_type,
            "ohmic_discretization": ohmic_discretization,
            "raw_delta": raw_delta,
            "delta_eff": delta_eff_f,
            "renormalization_p": renorm_p,
            "renormalization_factor": delta_eff_f / raw_delta,
            "high_frequency_cutoff": omega_l_f,
            "n_modes": n_modes,
            "discretization": ohmic_discretization,
            "omega_k": omega_k_arr.tolist(),
            "c_j2": c_j2_arr.tolist(),
            "converged": True,
        }
        save_output_parameters(output)
    except Exception as exc:
        import traceback

        save_output_parameters(
            {
                "calcjob_class": "OhmicRenormModesCalcJob",
                "calc_type": "ohmic_renorm_modes",
                "converged": False,
                "error": str(exc),
                "traceback": traceback.format_exc(),
            }
        )
        raise
