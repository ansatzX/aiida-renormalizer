"""Driver script for TtnsMutualInfoCalcJob.

Compute mutual information between nodes.
"""
import json
import numpy as np
from renormalizer.tn.treebase import BasisTree
from renormalizer.tn.tree import TTNS

# ============================================================================
# INPUT LOADING UTILITIES (from base template)
# ============================================================================

def load_basis_tree(input_file='input_basis_tree.npz'):
    """Load a BasisTree from .npz file."""
    return BasisTree.load(input_file)

def load_ttns(input_file='initial_ttns.npz', basis_tree=None):
    """Load a TTNS from .npz file."""
    if basis_tree is None:
        raise ValueError("BasisTree is required to load TTNS")
    return TTNS.load(basis_tree, input_file)

# ============================================================================
# OUTPUT SERIALIZATION UTILITIES (from base template)
# ============================================================================

def save_output_parameters(params, output_file='output_parameters.json'):
    """Save calculation outputs to JSON."""
    with open(output_file, 'w') as f:
        json.dump(params, f, indent=2)

# ============================================================================
# MAIN CALCULATION
# ============================================================================

if __name__ == '__main__':
    # Load inputs
    basis_tree = load_basis_tree()
    ttns = load_ttns('initial_ttns.npz', basis_tree)

    n_nodes = len(ttns)

    # Compute mutual information between nodes
    # Note: This requires RDM computation
    # Placeholder: compute based on tree structure and bond dimensions
    mutual_info_matrix = np.zeros((n_nodes, n_nodes))

    # For TTN, mutual information is related to the LCA (lowest common ancestor)
    # This is a simplified computation
    for i in range(n_nodes):
        for j in range(i+1, n_nodes):
            # Placeholder: use bond dimension at LCA as proxy
            # In practice, would need to compute 2-RDM for nodes i and j
            # and compute: I(i,j) = S(i) + S(j) - S(i,j)
            mutual_info_matrix[i, j] = 0.0
            mutual_info_matrix[j, i] = 0.0

    # Prepare output parameters
    output_params = {
        'calcjob_class': 'TtnsMutualInfoCalcJob',
        'calc_type': 'mutual_info',
        'mutual_info_matrix': mutual_info_matrix.tolist(),
        'n_nodes': n_nodes,
        'note': 'Mutual information computation requires 2-RDM calculation (not yet implemented)',
    }
    save_output_parameters(output_params)
