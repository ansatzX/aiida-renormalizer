"""Driver script for PropertyCalcJob.

Compute multiple observables from an MPS.
"""
import json
import numpy as np
from renormalizer.model import Model
from renormalizer.mps import Mps, Mpo

# ============================================================================
# INPUT LOADING UTILITIES (from base template)
# ============================================================================

def load_model(input_file='input_model.json'):
    """Load a Reno Model from AiiDA ModelData export."""
    with open(input_file, 'r') as f:
        data = json.load(f)

    from aiida_renormalizer.data.basis_registry import deserialize_basis
    basis = [deserialize_basis(b) for b in data['basis']]

    from aiida_renormalizer.data.op import deserialize_opsum
    ham_terms = deserialize_opsum(data['ham_opsum'])

    dipole = None
    if 'dipole' in data:
        dipole = deserialize_opsum(data['dipole'])

    return Model(basis, ham_terms, dipole=dipole)

def load_mps(input_file='initial_mps.npz', model=None):
    """Load an MPS/MpDm from .npz file."""
    if model is None:
        raise ValueError("Model is required to load MPS")
    return Mps.load(model, input_file)

def load_mpo(input_file, model=None):
    """Load an MPO from .npz file."""
    if model is None:
        raise ValueError("Model is required to load MPO")
    return Mpo.load(model, input_file)

# ============================================================================
# OUTPUT SERIALIZATION UTILITIES (from base template)
# ============================================================================

def save_output_parameters(params, output_file='output_parameters.json'):
    """Save calculation outputs to JSON."""
    with open(output_file, 'w') as f:
        json.dump(params, f, indent=2)

# ============================================================================
# MAIN CALCULATION
# ============================================================================

if __name__ == '__main__':
    # Load inputs
    model = load_model()
    mps = load_mps('initial_mps.npz', model)

    # Load observables manifest
    with open('observables_manifest.json', 'r') as f:
        manifest = json.load(f)

    # Compute each observable
    observables = {}

    for name, obs_info in manifest.items():
        obs_type = obs_info['type']
        obs_file = obs_info['file']

        if obs_type == 'mpo':
            # Load MPO and compute expectation
            mpo = load_mpo(obs_file, model)
            value = mps.expectation(mpo)
            observables[name] = float(value.real)

        elif obs_type == 'op':
            # Load Op and build MPO on the fly
            with open(obs_file, 'r') as f:
                op_data = json.load(f)

            from aiida_renormalizer.data.op import deserialize_opsum
            opsum = deserialize_opsum(op_data)

            # Build MPO
            mpo = Mpo(model, opsum)

            # Compute expectation
            value = mps.expectation(mpo)
            observables[name] = float(value.real)

    # Output parameters
    output_params = {
        'calcjob_class': 'PropertyCalcJob',
        'calc_type': 'property_scan',
        'observables': observables,
        'n_observables': len(observables),
        'bond_dims': [int(d) for d in mps.bond_dims],
        'bond_dims_mean': float(mps.bond_dims_mean),
        'n_sites': len(mps),
        'converged': True,
    }
    save_output_parameters(output_params)
