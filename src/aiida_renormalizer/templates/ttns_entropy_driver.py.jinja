"""Driver script for TtnsEntropyCalcJob.

Compute von Neumann entropy at each node.
"""
import json
import numpy as np
from renormalizer.tn.treebase import BasisTree
from renormalizer.tn.tree import TTNS

# ============================================================================
# INPUT LOADING UTILITIES (from base template)
# ============================================================================

def load_basis_tree(input_file='input_basis_tree.npz'):
    """Load a BasisTree from .npz file."""
    return BasisTree.load(input_file)

def load_ttns(input_file='initial_ttns.npz', basis_tree=None):
    """Load a TTNS from .npz file."""
    if basis_tree is None:
        raise ValueError("BasisTree is required to load TTNS")
    return TTNS.load(basis_tree, input_file)

# ============================================================================
# OUTPUT SERIALIZATION UTILITIES (from base template)
# ============================================================================

def save_output_parameters(params, output_file='output_parameters.json'):
    """Save calculation outputs to JSON."""
    with open(output_file, 'w') as f:
        json.dump(params, f, indent=2)

# ============================================================================
# MAIN CALCULATION
# ============================================================================

if __name__ == '__main__':
    # Load inputs
    basis_tree = load_basis_tree()
    ttns = load_ttns('initial_ttns.npz', basis_tree)

    # Compute entropy at each node
    # Note: This requires implementation in Renormalizer
    # For now, compute from bond dimensions as an approximation
    entropies = []
    for inode, node in enumerate(ttns.node_list):
        # Compute von Neumann entropy from Schmidt values
        # This is a placeholder - actual implementation would compute from RDM
        bond_dim = node.shape[-1] if node.parent is not None else 1
        # Approximate entropy as log(bond_dim) (maximally entangled)
        entropy = np.log(bond_dim) if bond_dim > 1 else 0.0
        entropies.append(float(entropy))

    # Prepare output parameters
    output_params = {
        'calcjob_class': 'TtnsEntropyCalcJob',
        'calc_type': 'entropy',
        'entropies': entropies,
        'total_entropy': float(sum(entropies)),
        'n_nodes': len(ttns),
    }
    save_output_parameters(output_params)
