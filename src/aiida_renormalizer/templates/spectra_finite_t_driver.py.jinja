"""Driver script for SpectraFiniteTCalcJob.

Finite-temperature absorption/emission spectrum calculation.
"""
import json
import numpy as np
from renormalizer.model import Model
from renormalizer.mps import Mps, Mpo, MpDm
from renormalizer.spectra import SpectraFiniteT
from renormalizer.utils import Quantity, EvolveConfig, CompressConfig

# ============================================================================
# INPUT LOADING UTILITIES (from base template)
# ============================================================================

def load_model(input_file='input_model.json'):
    """Load a Reno Model from AiiDA ModelData export."""
    with open(input_file, 'r') as f:
        data = json.load(f)

    from aiida_renormalizer.data.basis_registry import deserialize_basis
    basis = [deserialize_basis(b) for b in data['basis']]

    from aiida_renormalizer.data.op import deserialize_opsum
    ham_terms = deserialize_opsum(data['ham_opsum'])

    dipole = None
    if 'dipole' in data:
        dipole = deserialize_opsum(data['dipole'])

    return Model(basis, ham_terms, dipole=dipole)

def load_mps(input_file='initial_thermal_state.npz', model=None):
    """Load an MPS/MpDm from .npz file."""
    if model is None:
        raise ValueError("Model is required to load MPS")
    # For finite temperature, this is MpDm
    return MpDm.load(model, input_file)

def load_mpo(input_file='initial_mpo.npz', model=None):
    """Load an MPO from .npz file."""
    if model is None:
        raise ValueError("Model is required to load MPO")
    return Mpo.load(model, input_file)

def load_config(input_file='input_config.json'):
    """Load a Reno EvolveConfig."""
    try:
        with open(input_file, 'r') as f:
            data = json.load(f)
        from renormalizer.utils.configs import EvolveConfig
        fields = data.get('fields', {})
        return EvolveConfig(**fields)
    except FileNotFoundError:
        from renormalizer.utils.configs import EvolveConfig
        return EvolveConfig()

def load_evolve_config(input_file='input_ievolve_config.json'):
    """Load imaginary time evolve config."""
    try:
        with open(input_file, 'r') as f:
            data = json.load(f)
        from renormalizer.utils.configs import EvolveConfig
        fields = data.get('fields', {})
        return EvolveConfig(**fields)
    except FileNotFoundError:
        from renormalizer.utils.configs import EvolveConfig
        return EvolveConfig()

def load_compress_config(input_file='input_icompress_config.json'):
    """Load compress config."""
    try:
        with open(input_file, 'r') as f:
            data = json.load(f)
        from renormalizer.utils.configs import CompressConfig
        fields = data.get('fields', {})
        return CompressConfig(**fields)
    except FileNotFoundError:
        from renormalizer.utils.configs import CompressConfig
        return CompressConfig()

# ============================================================================
# OUTPUT SERIALIZATION UTILITIES (from base template)
# ============================================================================

def save_output_parameters(params, output_file='output_parameters.json'):
    """Save calculation outputs to JSON."""
    with open(output_file, 'w') as f:
        json.dump(params, f, indent=2)

# ============================================================================
# MAIN CALCULATION
# ============================================================================

if __name__ == '__main__':
    # Load inputs
    model = load_model()

    # Load spectrum parameters
    with open('input_spectra_params.json', 'r') as f:
        params = json.load(f)

    spectratype = params['spectratype']
    temperature = params['temperature']
    insteps = params.get('insteps', 1)
    gs_shift = params.get('gs_shift', 0)

    # Load configs
    config = load_config()
    ievolve_config = load_evolve_config()
    icompress_config = load_compress_config()

    # Load MPO (if provided)
    {% if has_mpo %}
    mpo = load_mpo('initial_mpo.npz', model)
    {% else %}
    mpo = Mpo(model)
    {% endif %}

    # Load initial thermal state (if provided)
    {% if has_initial_mps %}
    initial_thermal_state = load_mps('initial_thermal_state.npz', model)
    {% else %}
    initial_thermal_state = None
    {% endif %}

    # Create spectrum calculator
    spectra_calc = SpectraFiniteT(
        model,
        spectratype,
        Quantity(temperature, 'au'),
        insteps,
        Quantity(gs_shift, 'au'),
        evolve_config=config,
        icompress_config=icompress_config,
        ievolve_config=ievolve_config,
    )

    # Run calculation
    try:
        # The exact API call depends on TdMpsJob implementation
        spectra_calc.evolve(None, None, None)

        # Get results
        time_series = spectra_calc.evolve_times
        autocorr = spectra_calc.autocorr

        # Prepare output
        output_params = {
            'calcjob_class': 'SpectraFiniteTCalcJob',
            'calc_type': 'spectra',
            'spectratype': spectratype,
            'temperature': temperature,
            'time_series': [float(t) for t in time_series],
            'autocorr': [complex(c) for c in autocorr],
            'converged': True,
        }

        save_output_parameters(output_params)

    except Exception as e:
        import traceback
        output_params = {
            'calcjob_class': 'SpectraFiniteTCalcJob',
            'error': str(e),
            'traceback': traceback.format_exc(),
            'converged': False,
        }
        save_output_parameters(output_params)
        raise
