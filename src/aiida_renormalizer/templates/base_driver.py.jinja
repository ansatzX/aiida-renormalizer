"""Base driver script template — shared structure for all Reno CalcJobs.

This template provides common imports, input loading utilities, and output
serialization infrastructure. Subclass templates will fill in the actual
calculation logic.
"""
import json
import numpy as np
from renormalizer.model import Model
from renormalizer.mps import Mps, MpDm, Mpo
from renormalizer.model.basis import BasisSet

# ============================================================================
# INPUT LOADING UTILITIES
# ============================================================================

def load_model(input_file='input_model.json'):
    """Load a Reno Model from AiiDA ModelData export."""
    with open(input_file, 'r') as f:
        data = json.load(f)

    # Load basis (requires basis_registry dispatch)
    from aiida_renormalizer.data.basis_registry import deserialize_basis
    basis = [deserialize_basis(b) for b in data['basis']]

    # Load Hamiltonian
    from aiida_renormalizer.data.op import deserialize_opsum
    ham_terms = deserialize_opsum(data['ham_opsum'])

    # Load dipole (optional)
    dipole = None
    if 'dipole' in data:
        dipole = deserialize_opsum(data['dipole'])

    return Model(basis, ham_terms, dipole=dipole)

def load_config(input_file='input_config.json'):
    """Load a Reno config object from AiiDA ConfigData export."""
    with open(input_file, 'r') as f:
        data = json.load(f)

    from aiida_renormalizer.data.config import ConfigData
    # Reconstruct config (same logic as ConfigData.load_config)
    # This is a simplified version — full version needs all config types
    return data

def load_mps(input_file='initial_mps.npz', model=None):
    """Load an MPS/MpDm from .npz file."""
    if model is None:
        raise ValueError("Model is required to load MPS")
    return Mps.load(model, input_file)

def load_mpo(input_file='initial_mpo.npz', model=None):
    """Load an MPO from .npz file."""
    if model is None:
        raise ValueError("Model is required to load MPO")
    return Mpo.load(model, input_file)

# ============================================================================
# OUTPUT SERIALIZATION UTILITIES
# ============================================================================

def save_output_parameters(params, output_file='output_parameters.json'):
    """Save calculation outputs to JSON."""
    with open(output_file, 'w') as f:
        json.dump(params, f, indent=2)

def save_mps(mps, output_file='output_mps.npz', description=''):
    """Save MPS/MpDm to .npz with description field."""
    mps.dump(output_file.rstrip('.npz'))

    # Add description field
    with np.load(output_file, allow_pickle=True) as data:
        arrays = dict(data)
    arrays['description'] = description
    np.savez(output_file, **arrays)

def save_mpo(mpo, output_file='output_mpo.npz', description=''):
    """Save MPO to .npz with description field."""
    mpo.dump(output_file.rstrip('.npz'))

    # Add description field
    with np.load(output_file, allow_pickle=True) as data:
        arrays = dict(data)
    arrays['description'] = description
    np.savez(output_file, **arrays)

