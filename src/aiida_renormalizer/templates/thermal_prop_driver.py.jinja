"""Driver script for ThermalPropCalcJob.

Finite-temperature state preparation via thermal propagation.
"""
import json
import numpy as np
from renormalizer.model import Model
from renormalizer.mps import Mps, MpDm, Mpo

# ============================================================================
# INPUT LOADING UTILITIES (from base template)
# ============================================================================

def load_model(input_file='input_model.json'):
    """Load a Reno Model from AiiDA ModelData export."""
    with open(input_file, 'r') as f:
        data = json.load(f)

    from aiida_renormalizer.data.basis_registry import deserialize_basis
    basis = [deserialize_basis(b) for b in data['basis']]

    from aiida_renormalizer.data.op import deserialize_opsum
    ham_terms = deserialize_opsum(data['ham_opsum'])

    dipole = None
    if 'dipole' in data:
        dipole = deserialize_opsum(data['dipole'])

    return Model(basis, ham_terms, dipole=dipole)

def load_mpo(input_file='initial_mpo.npz', model=None):
    """Load an MPO from .npz file."""
    if model is None:
        raise ValueError("Model is required to load MPO")
    return Mpo.load(model, input_file)

def load_config(input_file='input_config.json'):
    """Load a Reno config object from AiiDA ConfigData export."""
    try:
        with open(input_file, 'r') as f:
            data = json.load(f)
        from renormalizer.utils.configs import EvolveConfig, EvolveMethod
        config_class = data.get('config_class', 'EvolveConfig')
        fields = data.get('fields', {})
        if 'method' in fields and isinstance(fields['method'], str):
            fields['method'] = EvolveMethod[fields['method']]
        return EvolveConfig(**fields)
    except FileNotFoundError:
        from renormalizer.utils.configs import EvolveConfig
        return EvolveConfig()

# ============================================================================
# OUTPUT SERIALIZATION UTILITIES (from base template)
# ============================================================================

def save_output_parameters(params, output_file='output_parameters.json'):
    """Save calculation outputs to JSON."""
    with open(output_file, 'w') as f:
        json.dump(params, f, indent=2)

def save_mpdm(mpdm, output_file='output_mps.npz', description=''):
    """Save MpDm to .npz with description field."""
    mpdm.dump(output_file.rstrip('.npz'))

    # Add description field
    with np.load(output_file, allow_pickle=True) as data:
        arrays = dict(data)
    arrays['description'] = description
    np.savez(output_file, **arrays)

# ============================================================================
# MAIN CALCULATION
# ============================================================================

if __name__ == '__main__':
    # Load inputs
    model = load_model()
    mpo = load_mpo('initial_mpo.npz', model)
    config = load_config()

    # Load thermal parameters
    with open('input_thermal_params.json', 'r') as f:
        thermal_params = json.load(f)

    temperature = thermal_params['temperature']
    n_iterations = thermal_params.get('n_iterations', 10)

    # Initialize thermal density matrix
    # Start from maximally mixed state (high temperature limit)
    mpdm = MpDm.maximally_mixed(model, m_max=50)

    # Thermal propagation (imaginary time to beta = 1/T)
    beta = 1.0 / temperature

    # Use thermal_prop method if available
    # Otherwise, do manual imaginary time propagation
    energy_trajectory = []

    try:
        # Try using thermal_prop if available
        for iteration in range(n_iterations):
            mpdm = mpdm.thermal_prop(mpo, temperature)
            # Compute energy
            energy = mpdm.expectation(mpo)
            energy_trajectory.append(energy.real)
    except (AttributeError, TypeError):
        # Fallback: manual imaginary time propagation
        # This is a simplified version
        dt = beta / n_iterations
        current_mpdm = mpdm

        for iteration in range(n_iterations):
            # Evolve by -i*dt (imaginary time)
            evolve_dt = -1j * dt
            current_mpdm = current_mpdm.evolve(mpo, evolve_dt, normalize=True)

            # Compute energy
            energy = current_mpdm.expectation(mpo)
            energy_trajectory.append(energy.real)

        mpdm = current_mpdm

    # Final results
    final_energy = energy_trajectory[-1]
    free_energy = final_energy - temperature * mpdm.entropy()  # F = E - TS

    output_params = {
        'calcjob_class': 'ThermalPropCalcJob',
        'calc_type': 'thermal_propagation',
        'temperature': temperature,
        'beta': beta,
        'n_iterations': n_iterations,
        'energy_trajectory': energy_trajectory,
        'final_energy': final_energy,
        'free_energy': free_energy,
        'bond_dims': [int(d) for d in mpdm.bond_dims],
        'bond_dims_mean': float(mpdm.bond_dims_mean),
        'n_sites': len(mpdm),
        'converged': True,
    }
    save_output_parameters(output_params)

    # Save thermal density matrix
    description = f'Thermal MpDm at T={temperature:.6f}, F={free_energy:.10f}'
    save_mpdm(mpdm, 'output_mps.npz', description)
