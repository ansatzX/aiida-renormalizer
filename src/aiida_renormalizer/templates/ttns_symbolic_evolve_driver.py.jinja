"""Driver script for symbolic TTNS evolution."""
import json
import numpy as np

from renormalizer.model import Op
from renormalizer.model import basis as ba
from renormalizer.tn import BasisTree, TTNO, TTNS
from renormalizer.utils.configs import EvolveConfig, EvolveMethod

if not hasattr(np, "product"):
    np.product = np.prod


def load_symbolic_inputs(input_file="input_symbolic.json"):
    with open(input_file, "r") as f:
        return json.load(f)


def load_evolution_params(input_file="input_evolution_params.json"):
    with open(input_file, "r") as f:
        data = json.load(f)
    return float(data["dt"]), int(data["nsteps"]), str(data["method"])


def build_basis_item(item):
    kind = item["kind"]
    dof = item["dof"]
    if kind == "half_spin":
        return ba.BasisHalfSpin(dof, item.get("sigmaqn", [0, 0]))
    if kind == "sho":
        return ba.BasisSHO(dof, omega=float(item["omega"]), nbas=int(item["nbas"]))
    raise ValueError(f"Unsupported basis kind: {kind}")


def build_op_item(item):
    dofs = item["dofs"]
    n_dofs = 1 if isinstance(dofs, str) else len(dofs)
    kwargs = {"factor": float(item.get("factor", 1.0))}
    if "qn" in item:
        qn = item["qn"]
        if not isinstance(qn, list):
            qn = [int(qn)] * n_dofs
        kwargs["qn"] = qn
    return Op(item["symbol"], dofs, **kwargs)


def save_output_parameters(params, output_file="output_parameters.json"):
    with open(output_file, "w") as f:
        json.dump(params, f, indent=2)


def save_ttns(ttns, output_file="output_ttns.npz", description=""):
    ttns.dump(output_file.rstrip(".npz"))
    with np.load(output_file, allow_pickle=True) as data:
        arrays = dict(data)
    arrays["description"] = description
    np.savez(output_file, **arrays)


if __name__ == "__main__":
    symbolic = load_symbolic_inputs()
    dt, nsteps, method_name = load_evolution_params()

    basis = [build_basis_item(x) for x in symbolic["basis"]]
    ham_terms = [build_op_item(x) for x in symbolic["hamiltonian"]]
    tree_type = symbolic.get("tree_type", "binary")
    m_max = int(symbolic.get("m_max", 16))

    if tree_type == "binary":
        basis_tree = BasisTree.binary(basis)
    elif tree_type == "linear":
        basis_tree = BasisTree.linear(basis)
    else:
        raise ValueError(f"Unsupported tree_type: {tree_type}")

    ttno = TTNO(basis_tree, ham_terms)
    ttns = TTNS.random(basis_tree, qntot=0, m_max=m_max)
    ttns.evolve_config = EvolveConfig(method=getattr(EvolveMethod, method_name))

    energies = [float(ttns.expectation(ttno))]
    times = [0.0]

    for i in range(nsteps):
        ttns = ttns.evolve(ttno, dt, normalize=True)
        energies.append(float(ttns.expectation(ttno)))
        times.append((i + 1) * dt)

    save_output_parameters(
        {
            "calcjob_class": "TtnsSymbolicEvolveCalcJob",
            "calc_type": "time_evolution",
            "tree_type": tree_type,
            "method": method_name,
            "dt": dt,
            "nsteps": nsteps,
            "time_points": times,
            "energy_trajectory": energies,
            "initial_energy": energies[0],
            "final_energy": energies[-1],
            "bond_dims": [int(d) for d in ttns.bond_dims],
            "n_nodes": len(ttns),
            "converged": True,
        }
    )

    save_ttns(ttns, "output_ttns.npz", f"TTNS symbolic evolved, final E={energies[-1]:.10f}")

    np.savez(
        "trajectory.npz",
        times=np.array(times, dtype=float),
        energies=np.array(energies, dtype=float),
    )
