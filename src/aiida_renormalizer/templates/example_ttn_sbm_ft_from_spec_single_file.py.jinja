def build_environment():
    sdf = ColeDavidsonSDF(float(INPUT["ita"]), float(INPUT["omega_c"]), float(INPUT["beta"]), float(MODEL["upper_limit"]))
    w, c2 = sdf.Wang1(int(MODEL["n_modes"]))
    c = np.sqrt(c2)
    delta_eff = float(MODEL["raw_delta"]) * sdf.reno(float(w[-1]))
    theta_array = np.arctanh(np.exp(-w / float(INPUT["temperature"]) / 2))
    return w, c, delta_eff, theta_array


