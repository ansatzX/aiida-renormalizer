"""Driver script for OptimizeTtnsCalcJob.

TTN variational optimization for ground state.
"""
import json
import numpy as np
from renormalizer.tn.treebase import BasisTree
from renormalizer.tn.tree import TTNS, TTNO
from renormalizer.tn.gs import optimize_ttns

# ============================================================================
# INPUT LOADING UTILITIES (from base template)
# ============================================================================

def load_basis_tree(input_file='input_basis_tree.npz'):
    """Load a BasisTree from .npz file."""
    return BasisTree.load(input_file)

def load_ttns(input_file='initial_ttns.npz', basis_tree=None):
    """Load a TTNS from .npz file."""
    if basis_tree is None:
        raise ValueError("BasisTree is required to load TTNS")
    return TTNS.load(basis_tree, input_file)

def load_ttno(input_file='input_ttno.npz', basis_tree=None):
    """Load a TTNO from .npz file."""
    if basis_tree is None:
        raise ValueError("BasisTree is required to load TTNO")
    return TTNO.load(basis_tree, input_file)

def load_config(input_file='input_config.json'):
    """Load a Reno config object from AiiDA ConfigData export."""
    try:
        with open(input_file, 'r') as f:
            data = json.load(f)
        # Reconstruct OptimizeConfig from data
        from renormalizer.parameter import OptimizeConfig
        config_class = data.get('config_class', 'OptimizeConfig')
        fields = data.get('fields', {})
        return OptimizeConfig(**fields)
    except FileNotFoundError:
        # Return default config
        from renormalizer.parameter import OptimizeConfig
        return OptimizeConfig()

# ============================================================================
# OUTPUT SERIALIZATION UTILITIES (from base template)
# ============================================================================

def save_output_parameters(params, output_file='output_parameters.json'):
    """Save calculation outputs to JSON."""
    with open(output_file, 'w') as f:
        json.dump(params, f, indent=2)

def save_ttns(ttns, output_file='output_ttns.npz', description=''):
    """Save TTNS to .npz with description field."""
    ttns.dump(output_file.rstrip('.npz'))

    # Add description field
    with np.load(output_file, allow_pickle=True) as data:
        arrays = dict(data)
    arrays['description'] = description
    np.savez(output_file, **arrays)

# ============================================================================
# MAIN CALCULATION
# ============================================================================

if __name__ == '__main__':
    # Load inputs
    basis_tree = load_basis_tree()
    ttno = load_ttno('input_ttno.npz', basis_tree)
    config = load_config()

    # Load or create initial TTNS
    {% if has_initial_ttns %}
    ttns = load_ttns('initial_ttns.npz', basis_tree)
    {% else %}
    # Create random TTNS as initial guess
    # Use bond dimension from config or default
    m_max = config.procedure[-1][0] if config.procedure else 50
    ttns = TTNS.random(basis_tree, qntot=0, m_max=m_max)
    {% endif %}

    # Apply config to TTNS
    ttns.optimize_config = config

    # Run TTN optimization
    energy_list = optimize_ttns(ttns, ttno)

    # Prepare output parameters
    final_energy = energy_list[-1] if energy_list else None

    output_params = {
        'calcjob_class': 'OptimizeTtnsCalcJob',
        'calc_type': 'optimization',
        'energy_trajectory': energy_list,
        'final_energy': final_energy,
        'ground_state_energy': final_energy,
        'n_iterations': len(energy_list),
        'bond_dims': [int(d) for d in ttns.bond_dims],
        'n_nodes': len(ttns),
        'converged': True,  # Would need to check actual convergence
    }
    save_output_parameters(output_params)

    # Save optimized TTNS with description
    description = f'TTN optimized state, E0={final_energy:.10f}'
    save_ttns(ttns, 'output_ttns.npz', description)
