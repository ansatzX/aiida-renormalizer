def build_tree_topology(basis):
    basis_by_dof = {item.dofs[0]: item for item in basis}
    built = {}

    for subtree in TOPOLOGY_SPEC.get("subtrees", []):
        kwargs = {"dummy_label": subtree["dummy_label"]}
        if subtree.get("contract_primitive"):
            kwargs["contract_primitive"] = True
        if "contract_label" in subtree:
            kwargs["contract_label"] = np.array(subtree["contract_label"], dtype=bool)
        basis_items = [basis_by_dof[dof] for dof in subtree["basis_dofs"]]
        built[subtree["subtree_id"]] = BasisTree.binary_mctdh(basis_items, **kwargs).root

    for node in TOPOLOGY_SPEC.get("assembly", []):
        basis_items = []
        for item in node["basis_items"]:
            if item["kind"] == "dof":
                basis_items.append(basis_by_dof[item["value"]])
            elif item["kind"] == "dummy":
                basis_items.append(BasisDummy(item["label"]))
            else:
                raise ValueError(f"unsupported topology basis item: {item}")
        tree_node = TreeNodeBasis(basis_items)
        children = [built[child_id] for child_id in node.get("children", [])]
        if children:
            tree_node.add_child(children)
        built[node["node_id"]] = tree_node

    return BasisTree(built[TOPOLOGY_SPEC["root"]])


def main() -> None:
    basis, ham_terms = build_model_with_op_and_basis()
    basis_tree = build_tree_topology(basis)
    ttno = TTNO(basis_tree, ham_terms)
    ttns = TTNS(basis_tree)
    ttns.compress_config = CompressConfig(CompressCriteria.fixed, max_bonddim=int(MODEL["m_max"]))
    ttns = expand_bond_dimension_general(ttns, ttno, ex_mps=None)
    ttns.evolve_config = EvolveConfig(EvolveMethod.tdvp_ps)
    print("preview_only=False: set evolve loop as needed", len(ttns))


if __name__ == "__main__":
    main()
