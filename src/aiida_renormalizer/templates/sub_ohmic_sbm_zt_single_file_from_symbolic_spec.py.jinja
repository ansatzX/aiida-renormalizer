TENSOR_NETWORK_SPEC = {{ tensor_network_spec_literal }}
DYNAMICS_PLAN = {{ dynamics_plan_literal }}
COLLECT_DATA_PLAN = {{ collect_data_plan_literal }}
REAL_RUN = {{ real_run_literal }}


def build_environment_variables():
    epsilon = float(PARAMETER_SHEET["epsilon"])
    delta_eff = float(ENVIRONMENT_MODEL_INFO["delta_eff"])
    nmodes = len(ENVIRONMENT_MODEL_INFO["omega_k"])
    return epsilon, delta_eff, nmodes


