"""Driver script for ImagTimeCalcJob.

Imaginary time evolution for ground state.
"""
import json
import numpy as np
from renormalizer.model import Model
from renormalizer.mps import Mps, Mpo

# ============================================================================
# INPUT LOADING UTILITIES (from base template)
# ============================================================================

def load_model(input_file='input_model.json'):
    """Load a Reno Model from AiiDA ModelData export."""
    with open(input_file, 'r') as f:
        data = json.load(f)

    from aiida_renormalizer.data.basis_registry import deserialize_basis
    basis = [deserialize_basis(b) for b in data['basis']]

    from aiida_renormalizer.data.op import deserialize_opsum
    ham_terms = deserialize_opsum(data['ham_opsum'])

    dipole = None
    if 'dipole' in data:
        dipole = deserialize_opsum(data['dipole'])

    return Model(basis, ham_terms, dipole=dipole)

def load_mps(input_file='initial_mps.npz', model=None):
    """Load an MPS/MpDm from .npz file."""
    if model is None:
        raise ValueError("Model is required to load MPS")
    return Mps.load(model, input_file)

def load_mpo(input_file='initial_mpo.npz', model=None):
    """Load an MPO from .npz file."""
    if model is None:
        raise ValueError("Model is required to load MPO")
    return Mpo.load(model, input_file)

def load_config(input_file='input_config.json'):
    """Load a Reno config object from AiiDA ConfigData export."""
    try:
        with open(input_file, 'r') as f:
            data = json.load(f)
        # Reconstruct EvolveConfig from data
        from renormalizer.utils.configs import EvolveConfig, EvolveMethod
        config_class = data.get('config_class', 'EvolveConfig')
        fields = data.get('fields', {})
        # Convert method string to enum if present
        if 'method' in fields and isinstance(fields['method'], str):
            fields['method'] = EvolveMethod[fields['method']]
        return EvolveConfig(**fields)
    except FileNotFoundError:
        # Return default config
        from renormalizer.utils.configs import EvolveConfig
        return EvolveConfig()

# ============================================================================
# OUTPUT SERIALIZATION UTILITIES (from base template)
# ============================================================================

def save_output_parameters(params, output_file='output_parameters.json'):
    """Save calculation outputs to JSON."""
    with open(output_file, 'w') as f:
        json.dump(params, f, indent=2)

def save_mps(mps, output_file='output_mps.npz', description=''):
    """Save MPS/MpDm to .npz with description field."""
    mps.dump(output_file.rstrip('.npz'))

    # Add description field
    with np.load(output_file, allow_pickle=True) as data:
        arrays = dict(data)
    arrays['description'] = description
    np.savez(output_file, **arrays)

# ============================================================================
# MAIN CALCULATION
# ============================================================================

if __name__ == '__main__':
    # Load inputs
    model = load_model()
    mpo = load_mpo('initial_mpo.npz', model)
    config = load_config()

    # Load evolution parameters
    with open('input_evolution_params.json', 'r') as f:
        evo_params = json.load(f)

    beta = evo_params['beta']
    dt = evo_params.get('dt', None)

    # Load or create initial MPS
    {% if has_initial_mps %}
    MPS = load_mps('initial_mps.npz', model)
    {% else %}
    # Create random MPS as initial state
    MPS = Mps.random(model, qntot=0, m_max=50)
    {% endif %}

    # Determine time step if not provided
    if dt is None:
        dt = 0.1  # Default time step

    # Perform imaginary time evolution
    # Note: imaginary time evolution uses negative imaginary dt
    n_steps = int(beta / dt)
    energy_trajectory = []

    current_MPS = MPS
    for step in range(n_steps):
        # Evolve by -i*dt (imaginary time step)
        evolve_dt = -1j * dt
        current_MPS = current_MPS.evolve(mpo, evolve_dt, normalize=True)

        # Compute energy
        energy = current_MPS.expectation(mpo)
        energy_trajectory.append(energy.real)

    # Final state
    final_MPS = current_MPS
    final_energy = energy_trajectory[-1]

    output_params = {
        'calcjob_class': 'ImagTimeCalcJob',
        'calc_type': 'optimization',
        'energy_trajectory': energy_trajectory,
        'final_energy': final_energy,
        'beta': beta,
        'dt': dt,
        'n_steps': n_steps,
        'bond_dims': [int(d) for d in final_MPS.bond_dims],
        'bond_dims_mean': float(final_MPS.bond_dims_mean),
        'n_sites': len(final_MPS),
        'converged': True,  # Would need actual convergence check
    }
    save_output_parameters(output_params)

    # Save final MPS with description
    description = f'Imaginary time evolved MPS, E={final_energy:.10f}'
    save_mps(final_MPS, 'output_mps.npz', description)
