"""Driver script for ModelFromSymbolicSpecCalcJob."""
import json


def save_output_parameters(params, output_file="output_parameters.json"):
    with open(output_file, "w") as handle:
        json.dump(params, handle, indent=2)


if __name__ == "__main__":
    with open("input_symbolic_model.json", "r") as handle:
        symbolic_inputs = json.load(handle)

    try:
        basis = symbolic_inputs.get("basis")
        hamiltonian = symbolic_inputs.get("hamiltonian")
        dipole = symbolic_inputs.get("dipole")

        if not isinstance(basis, list) or len(basis) == 0:
            raise ValueError("symbolic_inputs.basis must be a non-empty list")
        if not isinstance(hamiltonian, list) or len(hamiltonian) == 0:
            raise ValueError("symbolic_inputs.hamiltonian must be a non-empty list")
        if dipole is not None and not isinstance(dipole, list):
            raise ValueError("symbolic_inputs.dipole must be a list when provided")

        save_output_parameters(
            {
                "calcjob_class": "ModelFromSymbolicSpecCalcJob",
                "calc_type": "model_from_symbolic_spec",
                "converged": True,
                "symbolic_inputs": symbolic_inputs,
                "n_basis": len(basis),
                "n_hamiltonian_terms": len(hamiltonian),
                "has_dipole": dipole is not None,
            }
        )
    except Exception as exc:
        import traceback

        save_output_parameters(
            {
                "calcjob_class": "ModelFromSymbolicSpecCalcJob",
                "calc_type": "model_from_symbolic_spec",
                "converged": False,
                "error": str(exc),
                "traceback": traceback.format_exc(),
            }
        )
        raise
