"""Driver script for BathToMpoCoeffCalcJob."""
import json
import numpy as np


def save_output_parameters(params, output_file="output_parameters.json"):
    with open(output_file, "w") as f:
        json.dump(params, f, indent=2)


if __name__ == "__main__":
    with open("input_bath_to_mpo_coeff.json", "r") as f:
        p = json.load(f)

    frequency_scale = float(p["frequency_scale"])
    coupling_scale = float(p["coupling_scale"])
    omega_k = np.load("input_omega_k.npy")
    c_j2 = np.load("input_c_j2.npy")

    try:
        if omega_k.shape != c_j2.shape:
            raise ValueError("omega_k and c_j2 must have identical shape")
        if np.any(omega_k <= 0):
            raise ValueError("omega_k must be positive")
        if np.any(c_j2 < 0):
            raise ValueError("c_j2 must be non-negative")

        omega_scaled = omega_k * frequency_scale
        c_j2_scaled = c_j2 * coupling_scale
        displacement = np.sqrt(np.maximum(c_j2_scaled, 0.0)) / np.maximum(omega_scaled ** 2, 1e-15)
        g_k = np.sqrt(np.maximum(c_j2_scaled / np.maximum(omega_scaled, 1e-15), 0.0))

        reorg_energy = float(np.sum(c_j2_scaled / np.maximum(omega_scaled, 1e-15)))

        mode_terms = []
        for idx, (omega, c2, disp, gval) in enumerate(zip(omega_scaled, c_j2_scaled, displacement, g_k)):
            mode_terms.append(
                {
                    "mode_index": int(idx),
                    "omega": float(omega),
                    "c_j2": float(c2),
                    "displacement": float(disp),
                    "g_k": float(gval),
                }
            )

        output = {
            "calcjob_class": "BathToMpoCoeffCalcJob",
            "calc_type": "bath_to_mpo_coeff",
            "omega_k": omega_scaled.tolist(),
            "c_j2": c_j2_scaled.tolist(),
            "displacement": displacement.tolist(),
            "g_k": g_k.tolist(),
            "reorganization_energy": reorg_energy,
            "mode_terms": mode_terms,
            "converged": True,
        }
        save_output_parameters(output)
    except Exception as exc:
        import traceback
        save_output_parameters(
            {
                "calcjob_class": "BathToMpoCoeffCalcJob",
                "calc_type": "bath_to_mpo_coeff",
                "converged": False,
                "error": str(exc),
                "traceback": traceback.format_exc(),
            }
        )
        raise

