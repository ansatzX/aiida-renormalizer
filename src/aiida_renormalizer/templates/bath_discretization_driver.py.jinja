"""Driver script for BathDiscretizationCalcJob."""
import json
import numpy as np


def _discretize_trapz(omega_grid, j_omega, n_modes):
    edges = np.linspace(omega_grid[0], omega_grid[-1], n_modes + 1)
    omega_k = []
    c_j2 = []
    for i in range(n_modes):
        lo, hi = edges[i], edges[i + 1]
        if i == n_modes - 1:
            mask = (omega_grid >= lo) & (omega_grid <= hi)
        else:
            mask = (omega_grid >= lo) & (omega_grid < hi)
        w = omega_grid[mask]
        j = j_omega[mask]
        if len(w) < 2:
            wk = 0.5 * (lo + hi)
            jj = np.interp(wk, omega_grid, j_omega)
            area = float(jj * max(hi - lo, 0.0))
        else:
            area = float(np.trapz(j, w))
            weight = np.trapz(w * j, w)
            wk = float(weight / area) if area > 0 else float(np.mean(w))
        cj2 = (2.0 / np.pi) * wk * max(area, 0.0)
        omega_k.append(wk)
        c_j2.append(max(cj2, 0.0))
    return np.array(omega_k), np.array(c_j2)


def _discretize_equal_area(omega_grid, j_omega, n_modes):
    cumulative = np.zeros_like(omega_grid)
    cumulative[1:] = np.cumsum(0.5 * (j_omega[1:] + j_omega[:-1]) * np.diff(omega_grid))
    total = float(cumulative[-1])
    if total <= 0:
        raise ValueError("Total spectral weight must be positive for equal_area")
    targets = ((np.arange(n_modes) + 0.5) / n_modes) * total
    omega_k = np.interp(targets, cumulative, omega_grid)
    bin_area = total / n_modes
    c_j2 = (2.0 / np.pi) * omega_k * bin_area
    return omega_k, c_j2


def _discretize_wang1_like(omega_grid, j_omega, n_modes):
    omega_c = float(omega_grid[-1]) if float(omega_grid[-1]) > 0 else 1.0
    points = np.array(
        [-np.log(-float(j) / (n_modes + 1) + 1.0) * omega_c for j in range(1, n_modes + 1)]
    )
    points = np.clip(points, omega_grid[0], omega_grid[-1])
    j_interp = np.interp(points, omega_grid, j_omega)
    rho = (n_modes + 1) / omega_c * np.exp(-points / omega_c)
    c_j2 = 2.0 / np.pi * points * j_interp / np.maximum(rho, 1e-15)
    return points, np.maximum(c_j2, 0.0)


def save_output_parameters(params, output_file="output_parameters.json"):
    with open(output_file, "w") as f:
        json.dump(params, f, indent=2)


if __name__ == "__main__":
    with open("input_bath_discretization.json", "r") as f:
        p = json.load(f)

    n_modes = int(p["n_modes"])
    method = p["method"]
    omega_grid = np.load("input_omega_grid.npy")
    j_omega = np.load("input_j_omega.npy")

    try:
        if n_modes < 1:
            raise ValueError("n_modes must be >= 1")
        if omega_grid.shape != j_omega.shape:
            raise ValueError("omega_grid and j_omega must have identical shape")
        if len(omega_grid) < 2:
            raise ValueError("omega_grid must contain at least 2 points")
        if np.any(np.diff(omega_grid) <= 0):
            raise ValueError("omega_grid must be strictly increasing")
        if np.any(j_omega < 0):
            raise ValueError("j_omega contains negative values")

        if method == "trapz":
            omega_k, c_j2 = _discretize_trapz(omega_grid, j_omega, n_modes)
        elif method == "equal_area":
            omega_k, c_j2 = _discretize_equal_area(omega_grid, j_omega, n_modes)
        elif method == "wang1_like":
            omega_k, c_j2 = _discretize_wang1_like(omega_grid, j_omega, n_modes)
        else:
            raise ValueError(f"Unknown discretization method: {method}")

        displacement = np.sqrt(np.maximum(c_j2, 0.0)) / np.maximum(omega_k ** 2, 1e-15)

        output = {
            "calcjob_class": "BathDiscretizationCalcJob",
            "calc_type": "bath_discretization",
            "method": method,
            "n_modes": int(n_modes),
            "omega_k": omega_k.tolist(),
            "c_j2": c_j2.tolist(),
            "displacement": displacement.tolist(),
            "total_c_j2": float(np.sum(c_j2)),
            "converged": True,
        }
        save_output_parameters(output)
    except Exception as exc:
        import traceback
        save_output_parameters(
            {
                "calcjob_class": "BathDiscretizationCalcJob",
                "calc_type": "bath_discretization",
                "converged": False,
                "error": str(exc),
                "traceback": traceback.format_exc(),
            }
        )
        raise

